# ---------------------------------------------------
# NODELEARN CUSTOM IGNORES
# ---------------------------------------------------

# 1. Massive AI Models (CRITICAL: Prevents Git crash)
*.task
*.tflite
*.bin
assets/models/

# 2. Android Security Keys (Never share these publicly!)
*.jks
*.keystore
android/key.properties

# 3. Compiled Apps (Safety net just in case they escape the build folder)
*.apk
*.aab

# 4. Local Offline Databases (Hive)
*.hive
*.lock

# ---------------------------------------------------
# FLUTTER / DART (Recommended)
# ---------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
.pub-cache/
build/
coverage/

# CocoaPods / platform generated files
ios/Pods/
ios/.symlinks/
ios/Flutter/ephemeral/
macos/Pods/
macos/Flutter/ephemeral/

# IDEs
.idea/
.vscode/
*.iml

# OS / misc
.DS_Store
Thumbs.db
